{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Database=fitmind;Username=fitmind_user;Password=fitmind_pass"
  },
  "JwtSettings": {
    "SecretKey": "CHANGE_THIS_SECRET_KEY_MIN_32_CHARS_PRODUCTION",
    "Issuer": "FitMindAPI",
    "Audience": "FitMindClient",
    "ExpirationMinutes": 60,
    "RefreshExpirationDays": 7
  }
}
