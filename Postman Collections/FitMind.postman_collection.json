{
  "info": {
    "name": "FitMind API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000" },
    { "key": "accessToken", "value": "" },
    { "key": "refreshToken", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Gabriel Teste\",\n  \"email\": \"gabriel@teste.com\",\n  \"password\": \"Senha@123\",\n  \"phone\": \"11999999999\",\n  \"birthDate\": \"1999-01-01\",\n  \"sex\": \"Male\",\n  \"weight\": 80.0,\n  \"height\": 175.0,\n  \"limitations\": \"\",\n  \"goals\": [\"LoseWeight\", \"GainMuscle\"],\n  \"weeklyAvailability\": 4\n}"
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.accessToken) { pm.collectionVariables.set('accessToken', json.accessToken); }",
                  "if (json.refreshToken) { pm.collectionVariables.set('refreshToken', json.refreshToken); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"gabriel@teste.com\",\n  \"password\": \"Senha@123\"\n}"
            }
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/refresh",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"accessToken\": \"{{accessToken}}\",\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            }
          }
        },
        {
          "name": "Revoke Token",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/api/auth/revoke",
            "body": {
              "mode": "raw",
              "raw": "\"{{refreshToken}}\""
            }
          }
        },
        {
          "name": "Forgot Password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/forgot-password",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"gabriel@teste.com\"\n}"
            }
          }
        },
        {
          "name": "Reset Password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/reset-password",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"SEU_TOKEN_AQUI\",\n  \"newPassword\": \"NovaSenha@123\"\n}"
            }
          }
        }
      ]
    },
